#jinja2: trim_blocks: True, lstrip_blocks: True
<?xml version="1.0" encoding="UTF-8"?>
<!--
  {{ ansible_managed }}

  =============================================================================
  Apache Tomcat Application Context: {{ ctx_item.name }}
  =============================================================================
  Generated by Ansible - DO NOT EDIT MANUALLY
  =============================================================================
-->
<Context
  {% if ctx_item.doc_base is defined and ctx_item.doc_base | length > 0 %}
  docBase="{{ ctx_item.doc_base }}"
  {% endif %}
  reloadable="{{ ctx_item.reload_on_change | default(false) | string | lower }}"
  privileged="{{ ctx_item.privileged | default(false) | string | lower }}"
  override="{{ ctx_item.override | default(true) | string | lower }}"
  antiResourceLocking="{{ ctx_item.anti_resource_locking | default(false) | string | lower }}">

  {% if ctx_item.spring_config_location | default(false) | bool %}
  <!-- Spring Boot externalized config: loads properties from per-app config directory -->
  <Parameter name="spring.config.additional-location"
             value="file:{{ tomcat_app_catalina_base }}/config/{{ ctx_item.name }}/"
             override="false" />

  {% endif %}
  {% if ctx_item.datasources is defined and ctx_item.datasources | length > 0 %}
  <!-- JNDI DataSources (connection pools) -->
  {% for ds in ctx_item.datasources %}
  <Resource name="{{ ds.jndi_name }}"
            auth="Container"
            type="javax.sql.DataSource"
            factory="org.apache.tomcat.jdbc.pool.DataSourceFactory"
            driverClassName="{{ ds.driver_class }}"
            url="{{ ds.url }}"
            username="{{ ds.username }}"
            password="{{ ds.password }}"
            maxTotal="{{ ds.max_total | default(50) }}"
            maxIdle="{{ ds.max_idle | default(10) }}"
            minIdle="{{ ds.min_idle | default(5) }}"
            maxWaitMillis="{{ ds.max_wait_millis | default(10000) }}"
            validationQuery="{{ ds.validation_query | default('SELECT 1') }}"
            validationInterval="{{ ds.validation_interval | default(30000) }}"
            testOnBorrow="{{ ds.test_on_borrow | default(true) | string | lower }}"
            testWhileIdle="{{ ds.test_while_idle | default(true) | string | lower }}"
            removeAbandoned="{{ ds.remove_abandoned | default(true) | string | lower }}"
            removeAbandonedTimeout="{{ ds.remove_abandoned_timeout | default(300) }}"
            logAbandoned="{{ ds.log_abandoned | default(true) | string | lower }}" />

  {% endfor %}
  {% endif %}
  {% if ctx_item.environments is defined and ctx_item.environments | length > 0 %}
  <!-- JNDI Environment Entries -->
  {% for env in ctx_item.environments %}
  <Environment name="{{ env.name }}"
               type="{{ env.type }}"
               value="{{ env.value }}"
               override="{{ env.override | default(false) | string | lower }}" />

  {% endfor %}
  {% endif %}
  {% if ctx_item.resource_links is defined and ctx_item.resource_links | length > 0 %}
  <!-- Resource Links -->
  {% for rl in ctx_item.resource_links %}
  <ResourceLink name="{{ rl.name }}"
                global="{{ rl.global }}"
                type="{{ rl.type }}" />

  {% endfor %}
  {% endif %}
  {% if ctx_item.parameters is defined and ctx_item.parameters | length > 0 %}
  <!-- Context Parameters -->
  {% for param in ctx_item.parameters %}
  <Parameter name="{{ param.name }}"
             value="{{ param.value }}"
             override="{{ param.override | default(false) | string | lower }}" />

  {% endfor %}
  {% endif %}
</Context>
